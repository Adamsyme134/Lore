{
  "expo": {
    "name": "Lore",
    "slug": "lore",
    "version": "0.2.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "lore",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.adamsyme.lore"
    },
    "android": {
      "package": "com.adamsyme.lore",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E7"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lore uses location to place completed memories on your private map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Lore lets you attach photographs to completed quests.",
          "cameraPermission": "Lore lets you capture photographs when completing a quest."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Lore lets you capture photographs when completing a quest."
        }
      ],
      "expo-sharing",
      "expo-image",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11251d2e-ab96-431e-89e3-2c72063cddc2"
      }
    }
  }
}
